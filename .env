# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides

###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=2f9d8c7b6a5e4f3d2c1b0a9f8e7d6c5b
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Default points at the Dockerized PostgreSQL service ("db").
DATABASE_URL="postgresql://app:app@db:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Doctrine-backed (PostgreSQL) transport for async import processing.
MESSENGER_TRANSPORT_DSN="doctrine://default?queue_name=import"
###< symfony/messenger ###

###> app/api ###
# API key required in the X-API-Key header for every /api/* endpoint
# (programmatic access). Change before any real use.
API_KEY=change_me_super_secret_key
###< app/api ###

###> app/auth ###
# Dashboard login (username/password). The admin user is seeded on startup.
# Change these before any real use.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
###< app/auth ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###
