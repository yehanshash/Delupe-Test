# Defaults for the test environment.
APP_ENV=test
APP_DEBUG=0
APP_SECRET=test_secret

# Test database. In CI (GitHub Actions) and the test container this points at
# the local PostgreSQL service. Override with .env.test.local if needed.
DATABASE_URL="postgresql://app:app@127.0.0.1:5432/app_test?serverVersion=16&charset=utf8"

# Messenger runs in-memory during tests (no worker required).
MESSENGER_TRANSPORT_DSN="in-memory://"

# Fixed API key used by functional tests.
API_KEY=test_api_key

KERNEL_CLASS="App\Kernel"
